# ============================
# PSICEI / Sistema Administrativo TESJo
# Copia este archivo como ".env" y completa los valores
# ============================

# Entorno
PSICEI_APP_ENV=development
PSICEI_DEBUG=1
PSICEI_FORCE_HTTPS=0
PSICEI_SITE_URL=http://localhost/prueba/prueba

# Base de datos
PSICEI_DB_HOST=localhost
PSICEI_DB_USER=root
PSICEI_DB_PASS=
PSICEI_DB_NAME=ejemplo1

# Admin inicial (solo bootstrap)
PSICEI_ADMIN_USER=admin
PSICEI_ADMIN_EMAIL=admin@tesjo.edu.mx
PSICEI_ADMIN_AREA=Superusuario
PSICEI_ADMIN_PASSWORD=CAMBIAR_PASSWORD_SEGURO

# Rate limit de login
PSICEI_LOGIN_RATE_WINDOW_MIN=15
PSICEI_LOGIN_RATE_MAX_ATTEMPTS=6
PSICEI_SESSION_IDLE_TIMEOUT_MIN=120

# Captcha (opcional)
RECAPTCHA_ENABLED=0
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# IA (opcional)
AI_CHAT_PROVIDER=disabled
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_HTTP_TIMEOUT_SECONDS=45
